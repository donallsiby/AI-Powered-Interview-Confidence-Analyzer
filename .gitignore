frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Python ML Service
**/__pycache__/
**/*.pyc
ml-service/temp/
ml-service/venv/
ml-service/.venv/
ml-service/.pytest_cache/
